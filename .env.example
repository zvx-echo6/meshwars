# =============================================================================
# MeshWars configuration
# Copy this file to .env and edit the values below.
# =============================================================================

# --- REQUIRED ---
# The meshview instance MeshWars attaches to. Must include scheme.
MESHVIEW_BASE_URL=https://meshview.example.net

# --- Storage ---
# Where the SQLite database lives inside the container (mounted on a volume).
# DB_PATH=/data/game.db

# --- Upstream polling ---
# How often to poll the meshview API for new packets.
# POLL_INTERVAL_SECONDS=45
# Backfill window on startup so tiles fill in immediately.
# BACKFILL_HOURS=24
# Upstream rate cap (requests/second across all calls).
# UPSTREAM_RATE_PER_SEC=5.0
# Max concurrent packets_seen fan-out requests.
# UPSTREAM_CONCURRENCY=5

# --- Game rules ---
# Season length in days. Winner declared at end; teams re-drafted.
# SEASON_DAYS=30
# How long the winner banner stays up after a season closes.
# WINNER_BANNER_HOURS=72
# How many past seasons to retain in history view (rest are pruned).
# HISTORY_MAX=12
# Max hops a position packet can have to qualify. 99 = effectively unlimited.
# MAX_HOPS=99
# Comma-separated node roles excluded from the game (infrastructure).
# EXCLUDED_ROLES=ROUTER,ROUTER_LATE,CLIENT_BASE

# --- Fortress scoring ---
# Points awarded per qualifying position packet.
# SCORE_PER_PACKET=0.5
# One-time bonus per unique node painting a tile for a team.
# SCORE_PER_UNIQUE_NODE=1.0
# Per-day decay applied to all tile scores.
# SCORE_DECAY_PER_DAY=0.25
# Seconds a fresh capture is immune to being flipped.
# DEFENSE_WINDOW_SECONDS=900

# --- Server ---
# LISTEN_HOST=0.0.0.0
# LISTEN_PORT=8090

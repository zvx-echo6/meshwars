# =============================================================================
# MeshWars configuration
# Copy this file to .env and edit the values below.
# =============================================================================

# --- REQUIRED ---
# The meshview instance MeshWars attaches to. Must include scheme.
MESHVIEW_BASE_URL=https://meshview.example.net

# --- Hop filter ---
# Accept position packets where (hop_start - hop_limit) <= MAX_HOPS.
# The code default is 99 (effectively unlimited). Tighten only if you
# want to require positions to be heard very close to the source.
#MAX_HOPS=99

# --- Storage ---
# Path inside the container. The docker-compose mount provides /data.
#DB_PATH=/data/game.db

# --- Upstream polling ---
#POLL_INTERVAL_SECONDS=45
#BACKFILL_HOURS=24
#UPSTREAM_RATE_PER_SEC=5.0
#UPSTREAM_CONCURRENCY=5

# --- Game rules ---
#SEASON_DAYS=30
#WINNER_BANNER_HOURS=72
#HISTORY_MAX=12
#EXCLUDED_ROLES=ROUTER,ROUTER_LATE,CLIENT_BASE

# --- Fortress scoring ---
#SCORE_PER_PACKET=0.5
#SCORE_PER_UNIQUE_NODE=1.0
#SCORE_DECAY_PER_DAY=0.25
#DEFENSE_WINDOW_SECONDS=900

# --- Internal / advanced ---
#POSITION_APP_PORTNUM=3

# --- Server bind ---
#LISTEN_HOST=0.0.0.0
#LISTEN_PORT=8090
